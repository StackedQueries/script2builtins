{
  "name": "script2builtins-knowledge",
  "version": "0.1.0",
  "description": "Shared API catalog for the script2builtins family: ALL_APIS, the watched-root index, the endpoint classifier, and the catalog-shape types (ApiDefinition, Severity, SokLayer). Consumed by both script2builtins (static analyzer) and script2builtins-runtime (dynamic analyzer); ships independently so catalog updates don't require a static-analyzer release.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "bot-detection",
    "fingerprinting",
    "anti-bot",
    "catalog",
    "browser-apis"
  ],
  "author": "Tyler Richards <tyler@richards.foo>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/StackedQueries/script2builtins.git",
    "directory": "packages/script2builtins-knowledge"
  },
  "bugs": {
    "url": "https://github.com/StackedQueries/script2builtins/issues"
  },
  "homepage": "https://github.com/StackedQueries/script2builtins#readme",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
